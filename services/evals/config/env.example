# Eval & Observability environment variables.
# Copy this file to config/.env and fill in the values.

# --- Provider keys (for Promptfoo provider-comparison evals) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# --- Langfuse (optional — integration degrades safely without these) ---
# LANGFUSE_HOST=http://localhost:3002
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

# --- CaseGraph API (for HTTP-based eval targets) ---
CASEGRAPH_API_URL=http://localhost:8000
CASEGRAPH_AGENT_RUNTIME_URL=http://localhost:8100
