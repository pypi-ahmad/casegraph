# Local environment reference.
# For Next.js/Auth.js, copy the web-app variables into apps/web/.env.local.
# For shared local service overrides, copy the relevant values into a repo-root .env if needed.

# API
CASEGRAPH_DEBUG=false
CASEGRAPH_WEB_ORIGIN=http://localhost:3000
CASEGRAPH_PROVIDER_REQUEST_TIMEOUT_SECONDS=15
CASEGRAPH_AGENT_RUNTIME_URL=http://localhost:8100
CASEGRAPH_AGENT_RUNTIME_TIMEOUT_SECONDS=10

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Auth (Auth.js / next-auth)
# Generate a secret:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=change-me-to-a-random-secret
AUTH_TRUST_HOST=true

# Local bootstrap user (credentials provider)
# Generate a password hash:  cd apps/web && node -e "import('bcryptjs').then(b=>b.hash('YOUR_PASSWORD',10).then(console.log))"
AUTH_USER_1_EMAIL=admin@local.dev
AUTH_USER_1_NAME=Admin
AUTH_USER_1_PASSWORD_HASH=$2b$10$.p920oM/b0XYhvza/TeOSeCZ5DQ12iOaTeMjoM.sbrjF9eAjMCZTu
# AUTH_USER_1_ROLE=admin  # optional: "admin" (default) or "member"

# Langfuse (optional — observability/tracing)
# LANGFUSE_HOST=http://localhost:3002
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
