# CaseGraph environment configuration
# Copy to .env and fill in the values you need.

# ── LLM provider keys (BYOK — bring your own) ────────────────────
# At least one key is needed for extraction, tasks, RAG, and evals.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Observability (optional) ─────────────────────────────────────
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── API settings ─────────────────────────────────────────────────
API_PORT=8000
AGENT_RUNTIME_PORT=8100
AGENT_RUNTIME_URL=http://localhost:8100

# ── Auth (frontend) ─────────────────────────────────────────────
AUTH_SECRET=change-me-to-a-random-string
